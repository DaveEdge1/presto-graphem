# Editor / workspace
.claude/
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
.Rproj.user/
.Rhistory
.RData

# Bootstrap scratch dirs (handy if you clone reference repos for cross-checking)
_refs/
_*_src/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
env/
venv/

# Conda (in case authors build envs locally)
.conda/

# R / cmdstan build artifacts
*.o
*.so
*.dll
*-stan

# Build / log output
build.log
build*.log
*.log

# Workflow output (uploaded as artifact + committed via `git add -f` in CI)
outputs/
results/
recons/
validation/

# Tmp scratch from one-off comparisons or debug runs
tmp_*/
*_tmp/

# Large data dumps generated by debug runs
lipd_legacy.pkl
lipd_data.pkl
lipd_cfr.pkl
lipd_output/
*.nc
*.h5
*.hdf5
